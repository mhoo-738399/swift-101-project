import Foundation

class Book {
    // خصائص مطلوبة (Required)
    let id: Int
    var title: String
    var author: String
    
    // خصائص اختيارية (Optional)
    var price: Double?
    var quantity: Int?
    
    // المشيد (Initializer)
    init(id: Int, title: String, author: String, price: Double? = nil, quantity: Int? = nil) {
        self.id = id
        self.title = title
        self.author = author
        self.price = price
        self.quantity = quantity
    }
    
    // دالة لعرض معلومات الكتاب مع التعامل مع القيم الاختيارية بأمان
    func displayInfo() {
        let bookPrice = price != nil ? "\(price!) ريال" : "غير محدد"
        let bookQuantity = quantity != nil ? "\(quantity!)" : "غير محدد"
        
        print("""
        -----------------------------------
        رقم الكتاب: \(id)
        العنوان: \(title)
        المؤلف: \(author)
        السعر: \(bookPrice)
        الكمية المتاحة: \(bookQuantity)
        -----------------------------------
        """)
    }
}

class Bookstore {
    var inventory: [Book] = []
    
    // 1. إضافة كتاب جديد
    func addBook(_ book: Book) {
        inventory.append(book)
        print("✅ تم إضافة كتاب '\(book.title)' بنجاح.")
    }
    
    // 2. تعديل معلومات كتاب
    func updateBook(id: Int, newTitle: String?, newAuthor: String?, newPrice: Double?, newQuantity: Int?) {
        if let book = inventory.first(where: { $0.id == id }) {
            if let title = newTitle { book.title = title }
            if let author = newAuthor { book.author = author }
            if let price = newPrice { book.price = price }
            if let quantity = newQuantity { book.quantity = quantity }
            print("🔄 تم تحديث بيانات الكتاب رقم \(id) بنجاح.")
        } else {
            print("❌ عذرًا، الكتاب رقم \(id) غير موجود.")
        }
    }
    
    // 3. حذف كتاب
    func deleteBook(id: Int) {
        if let index = inventory.firstIndex(where: { $0.id == id }) {
            let removedBook = inventory.remove(at: index)
            print("🗑️ تم حذف كتاب '\(removedBook.title)' من النظام.")
        } else {
            print("❌ عذرًا، لم يتم العثور على الكتاب لحذفه.")
        }
    }
    
    // 4. الاستعلام عن كتاب (البحث)
    func searchBook(byQuery query: String) {
        let results = inventory.filter { book in
            String(book.id) == query || 
            book.title.lowercased().contains(query.lowercased()) || 
            book.author.lowercased().contains(query.lowercased())
        }
        
        if results.isEmpty {
            print("🔍 لا توجد نتائج للبحث عن: '\(query)'")
        } else {
            print("🔍 نتائج البحث (\(results.count)):")
            for book in results {
                book.displayInfo()
            }
        }
    }
    
    // 5. بيع كتاب وتصدير فاتورة
    func sellBook(id: Int, requestedQuantity: Int) {
        // التحقق من وجود الكتاب
        guard let book = inventory.first(where: { $0.id == id }) else {
            print("❌ عملية البيع فشلت: الكتاب غير موجود بالنظام.")
            return
        }
        
        // التحقق من وجود كمية كافية (مفهوم الـ Optional Unwrapping هنا أساسي)
        if let currentQuantity = book.quantity {
            if currentQuantity >= requestedQuantity {
                // إنقاص المخزون
                book.quantity = currentQuantity - requestedQuantity
                
                // حساب السعر الإجمالي إن وجد
                let singlePrice = book.price ?? 0.0
                let totalPrice = singlePrice * Double(requestedQuantity)
                
                // تصدير الفاتورة
                printInvoice(bookTitle: book.title, qty: requestedQuantity, unitPrice: singlePrice, total: totalPrice)
                
            } else {
                print("⚠️ تنبيه: الكمية المطلوبة من '\(book.title)' غير متوفرة! المتاح في المخزن: \(currentQuantity) فقط.")
            }
        } else {
            print("⚠️ تنبيه: هذا الكتاب ليس له كمية محددة في المخزن (غير متاح للبيع حاليًا).")
        }
    }
    
    // دالة مساعدة لطباعة الفاتورة
    private func printInvoice(bookTitle: String, qty: Int, unitPrice: Double, total: Double) {
        print("""
        
        ===================================
        🧾 فاتورة مبيعات 🧾
        ===================================
        الكتاب: \(bookTitle)
        الكمية المباعة: \(qty)
        سعر الوحدة: \(unitPrice) ريال
        -----------------------------------
        الإجمالي الإجمالي: \(total) ريال
        ===================================
        """)
    }
}
// إنشاء نظام المكتبة
let myStore = Bookstore()

// تغذية النظام ببيانات الجدول المرفق
myStore.addBook(Book(id: 1, title: "Start with why", author: "Simon Sinek", price: 80.0, quantity: 13))
myStore.addBook(Book(id: 2, title: "But how do it know", author: "J. Clark Scott", price: 59.9, quantity: 22))
myStore.addBook(Book(id: 3, title: "Clean Code", author: "Robert Cecil Martin", price: 50.0, quantity: 5))
myStore.addBook(Book(id: 4, title: "Zero to One", author: "Peter Thiel", price: 45.0, quantity: 12))
myStore.addBook(Book(id: 5, title: "You don't know JS", author: "Kyle Simpson", price: 39.9, quantity: 9))

print("\n--- 🧪 تجربة عمليات النظام 🧪 ---\n")

// تجربة الاستعلام (البحث) عن طريق اسم المؤلف أو العنوان
myStore.searchBook(byQuery: "Simon")
myStore.searchBook(byQuery: "Clean Code")

// تجربة عملية بيع ناجحة (كمية كافية)
myStore.sellBook(id: 3, requestedQuantity: 2) // بيع قطعتين من Clean Code (المخزن سيصبح 3)

// تجربة عملية بيع تفشل (كمية غير كافية)
myStore.sellBook(id: 3, requestedQuantity: 5) // سيظهر تنبيه لأن المتبقي 3 فقط

// تجربة تعديل كتاب وعرض معلوماته بعد التعديل
myStore.updateBook(id: 5, newTitle: "You don't know Swift", newAuthor: nil, newPrice: 42.0, newQuantity: 15)
myStore.searchBook(byQuery: "5")
